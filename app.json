{
  "expo": {
    "name": "weyne-calculator",
    "slug": "weyne-calculator",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/alemu.png",
    "scheme": "weynecalculator",
    "userInterfaceStyle": "automatic",
    "ios": { "supportsTablet": true },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#E6F4FE",
        "foregroundImage": "./assets/alemu.png"
      },
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false
    },
    "web": {
      "output": "static",
      "favicon": "./assets/alemu.png"
    },
    "plugins": [
      [
        "expo-splash-screen",
        {
          "image": "./assets/alemu.png",
          "imageWidth": 200,
          "resizeMode": "contain",
          "backgroundColor": "#ffffff"
        }
      ]
    ],
    "experiments": { "typedRoutes": true, "reactCompiler": true }
  }
}